# ── Server ───────────────────────────────────────────────
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────
# Option A: Connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devopssrepractice

# Option B: Individual vars (used if DATABASE_URL is not set)
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=devopssrepractice
# PG_USER=postgres
# PG_PASSWORD=postgres

# ── Authentication ───────────────────────────────────────
JWT_SECRET=change-me-use-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# ── Email (SMTP) ────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# CONTACT_TO_EMAIL=team@devopssrepractice.com

# ── Contentful CMS ──────────────────────────────────────
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=
# CONTENTFUL_PREVIEW_TOKEN=
# CONTENTFUL_ENVIRONMENT=master
# CONTENTFUL_WEBHOOK_SECRET=

# ── Rebuild Hook (triggered by Contentful webhook) ──────
# REBUILD_HOOK_URL=https://api.vercel.app/v1/integrations/deploy/...
